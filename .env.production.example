# LabMaster Egypt - Production Environment
# Copy to .env.production and fill in values
# NEVER commit .env.production to git

# Isolated ports (safe defaults — won't conflict with 80/443/3000/8000/5432)
LABMASTER_WEB_PORT=13000
LABMASTER_API_PORT=18000
LABMASTER_DB_PORT=15432
LABMASTER_REDIS_PORT=16379

# Database
POSTGRES_USER=labmaster
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=labmaster

# Security — generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_OPENSSL_RAND_HEX_32
BOOTSTRAP_ADMINS=false
ALLOW_DEMO_SEED=false
# Set BOOTSTRAP_ADMINS=true once only, with a strong password, to create the first platform admin.
PLATFORM_ADMIN_USERNAME=superadmin
PLATFORM_ADMIN_PASSWORD=

# Domain — set automatically by setup-domain.sh, or edit manually:
# LABMASTER_DOMAIN=labmaster.yourdomain.com
# NEXT_PUBLIC_API_URL=https://labmaster.yourdomain.com/api/v1
# CORS_ORIGINS=["https://labmaster.yourdomain.com"]
NEXT_PUBLIC_API_URL=http://127.0.0.1:18000/api/v1
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=false
CORS_ORIGINS=["http://127.0.0.1:13000"]
