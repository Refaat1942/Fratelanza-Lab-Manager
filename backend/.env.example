DATABASE_URL=postgresql+asyncpg://labmaster:labmaster@localhost:5432/labmaster
DATABASE_URL_SYNC=postgresql://labmaster:labmaster@localhost:5432/labmaster
# Optional: separate platform registry DB (defaults to DATABASE_URL)
# PLATFORM_DATABASE_URL=
# PLATFORM_DATABASE_URL_SYNC=
# Each customer laboratory gets its own PostgreSQL database (labmaster_tenant_<code>)
TENANT_DATABASE_PER_CUSTOMER=true
TENANT_DATABASE_PREFIX=labmaster_tenant_
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
CORS_ORIGINS=["http://localhost:3000"]
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=development
DEBUG=true
